{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Aspire": {
    "Dashboard": {
      "Enabled": true,
      "Path": "/aspire-dashboard"
    },
    "Telemetry": {
      "ServiceName": "WebAppDI",
      "Sampling": {
        "Probability": 1.0
      }
    }
  },
  "OpenTelemetry": {
    "Metrics": {
      "AspNetCore": true,
      "HttpClient": true,
      "Process": true,
      "Runtime": true
    }
  }
}
